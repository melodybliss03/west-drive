# WestDrive Frontend Environment Variables
# Copy this file to .env.local (or .env) and adjust values for your environment.

# API base URL used by the centralized API client.
# The app resolves URL based on Vite mode:
# - DEV  => VITE_API_BASE_URL_DEV (fallback: VITE_API_BASE_URL)
# - PROD => VITE_API_BASE_URL_PROD (fallback: VITE_API_BASE_URL)

# Optional legacy fallback (used when *_DEV/*_PROD are missing)
VITE_API_BASE_URL=https://api.pariswestdrive.fr

# Development
VITE_API_BASE_URL_DEV=https://api.pariswestdrive.fr

# Production
VITE_API_BASE_URL_PROD=https://api.pariswestdrive.fr

# Notes
# - Stripe keys are configured on the backend (not in frontend env) because checkout
#   sessions are created server-side.
# - FRONTEND_BASE_URL must be configured in backend env to build Stripe success/cancel URLs.
