# WestDrive Frontend Environment Variables
# Copy this file to .env.local (or .env) and adjust values for your environment.

# Required
# Backend API base URL used by the centralized API client.
# Local dev backend: http://localhost:3000
# Render/production example: https://westdrive.onrender.com
VITE_API_BASE_URL=http://localhost:3000

# Notes
# - Stripe keys are configured on the backend (not in frontend env) because checkout
#   sessions are created server-side.
# - FRONTEND_BASE_URL must be configured in backend env to build Stripe success/cancel URLs.
