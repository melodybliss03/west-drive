NODE_ENV=production
PORT=3000

# Public API URL allowed by CORS (frontend domain)
CORS_ORIGIN=https://app.your-domain.com
FRONTEND_BASE_URL=https://app.your-domain.com

# Postgres connection string (using compose service name db)
DATABASE_URL=postgresql://westdrive:CHANGE_ME_DB_PASSWORD@db:5432/westdrive?schema=public
DB_SSL=false
DB_RESET=false

# JWT secrets (generate long random strings)
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# Admin bootstrap user
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_FIRST_NAME=WestDrive
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=+33000000000

# SMTP (Hostinger)
MAIL_ENABLED=true
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=contact@your-domain.com
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_FROM_EMAIL=contact@your-domain.com
MAIL_FROM_NAME=WestDrive

# Cloudinary
CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
CLOUDINARY_FOLDER=westdrive

# Stripe
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Frontend Docker build (served on main domain)
VITE_API_BASE_URL_PROD=https://api.your-domain.com
