# Runtime
NODE_ENV=development
PORT=3000

# Frontend URL used by backend for links (invitation, Stripe success/cancel)
FRONTEND_BASE_URL=http://localhost:8080

# CORS
CORS_WHITELIST=http://localhost:3001
CORS_ALLOW_NO_ORIGIN=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ORIGIN=http://localhost:3001

# Database
DATABASE_URL=postgres://westdrive:westdrive_password@localhost:5432/westdrive
DB_SSL=false
DB_RESET=false

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_please
JWT_REFRESH_SECRET=change_me_refresh_secret_please
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_FIXED_ENABLED=true
OTP_FIXED_CODE=123456
REGISTER_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_TTL_MINUTES=10

# SMTP (Hostinger example)
MAIL_ENABLED=false
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=noreply@your-domain.com
MAIL_PASSWORD=change_me_hostinger_mail_password
MAIL_FROM_EMAIL=noreply@your-domain.com
MAIL_FROM_NAME=WestDrive

# Stripe sandbox/production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=westdrive

# Seed admin user
ADMIN_EMAIL=admin@westdrive.fr
ADMIN_PASSWORD=ChangeMeStrongPassword
ADMIN_FIRST_NAME=WestDrive
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=+33000000000
